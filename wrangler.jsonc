{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "aidailypick",
  "compatibility_date": "2026-05-03",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "aidailypick"
    }
  ]
}
